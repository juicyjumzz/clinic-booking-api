# Copy this file to .env and adjust values for local development.
# All of these have sensible defaults in app/core/config.py, so .env is
# optional for local runs - it's here mainly to document what's
# configurable.

DATABASE_URL=sqlite:///./clinic.db
CLINIC_TIMEZONE=Africa/Nairobi
SLOT_MINUTES=30
MIN_LEAD_TIME_MINUTES=60
